<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="OpenWhisper"
           Version="0.3.4.0"
           Manufacturer="OpenWhisper Contributors"
           UpgradeCode="8A5E3B2D-1F4C-4E6A-9B7D-2C8F5A3E1D0B"
           Language="1033"
           Codepage="1252"
           InstallerVersion="500"
           Scope="perMachine">

    <SummaryInformation Description="OpenWhisper - Local-first dictation assistant for Windows"
                        Manufacturer="OpenWhisper Contributors" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of OpenWhisper is already installed." />

    <Media Id="1" Cabinet="OpenWhisper.cab" EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="OpenWhisperIcon" SourceFile="assets\icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="OpenWhisperIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/fsouza-dot/OpenWhisper" />

    <!-- Check for Visual C++ Redistributable 2015-2022 (x64) -->
    <Property Id="VCREDIST_INSTALLED">
      <RegistrySearch Id="VCRedist_RegSearch"
                      Root="HKLM"
                      Key="SOFTWARE\Microsoft\VisualStudio\14.0\VC\Runtimes\x64"
                      Name="Installed"
                      Type="raw" />
    </Property>

    <!-- Alternative check via file existence -->
    <Property Id="VCRUNTIME_EXISTS">
      <DirectorySearch Id="SystemFolderSearch" Path="[System64Folder]">
        <FileSearch Id="VCRuntime140Search" Name="vcruntime140.dll" />
      </DirectorySearch>
    </Property>

    <!-- Launch condition: require VC++ Redistributable -->
    <Launch Condition="VCREDIST_INSTALLED OR VCRUNTIME_EXISTS"
            Message="OpenWhisper requires the Microsoft Visual C++ Redistributable (x64).&#13;&#13;Please download and install it from:&#13;https://aka.ms/vs/17/release/vc_redist.x64.exe&#13;&#13;Then run this installer again." />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="OpenWhisper" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="OpenWhisper" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Files Include="dist\OpenWhisper\**" />
    </ComponentGroup>

    <Component Id="StartMenuShortcutComponent" Guid="2B3C4D5E-6F7A-8B9C-0D1E-2F3A4B5C6D7E" Directory="ApplicationProgramsFolder">
      <Shortcut Id="StartMenuShortcut"
                Name="OpenWhisper"
                Target="[INSTALLFOLDER]OpenWhisper.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="OpenWhisperIcon" />
      <RemoveFolder Id="RemoveStartMenuFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\OpenWhisper" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Component Id="DesktopShortcutComponent" Guid="3C4D5E6F-7A8B-9C0D-1E2F-3A4B5C6D7E8F" Directory="DesktopFolder">
      <Shortcut Id="DesktopShortcut"
                Name="OpenWhisper"
                Target="[INSTALLFOLDER]OpenWhisper.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="OpenWhisperIcon" />
      <RegistryValue Root="HKCU" Key="Software\OpenWhisper" Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Feature Id="ProductFeature" Title="OpenWhisper" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="StartMenuShortcutComponent" />
      <ComponentRef Id="DesktopShortcutComponent" />
    </Feature>

  </Package>
</Wix>
